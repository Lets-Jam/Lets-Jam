{
  "name": "band-web",
  "private": true,
  "version": "1.0.0",
  "main": "clickBand/server.js",
  "workspaces": [
    "clickBand",
    "clickBand-ui"
  ],
  "scripts": {
    "dev": "npm run start",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "npm run start --workspace clickBand",
    "start:frontend": "npm run dev --workspace clickBand-ui"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

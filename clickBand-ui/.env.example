# Optional: set this when the socket server is on a different host/domain.
# If omitted, the app connects to the current page origin.
# VITE_SOCKET_URL=https://192.168.0.10:3000

# Local dev proxy target for Vite -> backend socket server.
# VITE_DEV_PROXY_TARGET=https://127.0.0.1:3000

# Optional local HTTPS certificates for Vite dev server.
# VITE_SSL_KEY_PATH=/absolute/path/to/localhost-key.pem
# VITE_SSL_CERT_PATH=/absolute/path/to/localhost.pem
